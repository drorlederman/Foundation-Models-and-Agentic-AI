% shared/beamerthemeHIT.sty
% HIT-branded Beamer theme for "Foundation Models and Agentic AI"
% Inherits from Metropolis; falls back gracefully if Metropolis is absent.

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{beamerthemeHIT}[2024/01/01 HIT Beamer Theme]

% ── Attempt to load Metropolis; fall back to AnnArbor ────────────────────────
\IfFileExists{beamerthememetropolis.sty}{%
  \usetheme[progressbar=frametitle,
            numbering=fraction,
            block=fill,
            sectionpage=progressbar]{metropolis}%
  \def\HITthemeloaded{metropolis}%
}{%
  \usetheme{AnnArbor}%
  \def\HITthemeloaded{annarbor}%
}

% ── HIT color palette ─────────────────────────────────────────────────────────
\definecolor{hitblue}{RGB}{0,51,102}        % deep navy
\definecolor{hitgold}{RGB}{192,148,0}       % academic gold
\definecolor{hitlightblue}{RGB}{220,232,245}
\definecolor{hitdark}{RGB}{20,20,40}
\definecolor{hitalert}{RGB}{180,30,30}

% ── Apply colors ──────────────────────────────────────────────────────────────
\setbeamercolor{palette primary}{bg=hitblue, fg=white}
\setbeamercolor{palette secondary}{bg=hitblue!80, fg=white}
\setbeamercolor{palette tertiary}{bg=hitblue!60, fg=white}
\setbeamercolor{palette quaternary}{bg=hitblue!40, fg=white}
\setbeamercolor{structure}{fg=hitblue}
\setbeamercolor{alerted text}{fg=hitalert}
\setbeamercolor{example text}{fg=hitblue!70!black}
\setbeamercolor{block title}{bg=hitblue, fg=white}
\setbeamercolor{block body}{bg=hitlightblue}
\setbeamercolor{block title alerted}{bg=hitalert, fg=white}
\setbeamercolor{block body alerted}{bg=hitalert!10}
\setbeamercolor{block title example}{bg=hitblue!70!black, fg=white}
\setbeamercolor{block body example}{bg=hitblue!8}

% Progress bar color (Metropolis only)
\@ifundefined{HITthemeloaded}{}{%
  \ifx\HITthemeloaded\detokenize{metropolis}
    \setbeamercolor{progress bar}{fg=hitgold, bg=hitblue!30}
    \setbeamercolor{title separator}{fg=hitgold}
    \setbeamercolor{frametitle}{bg=hitblue, fg=white}
  \fi
}

% ── Fonts ─────────────────────────────────────────────────────────────────────
% Metropolis already pulls in FiraSans/FiraMono; for AnnArbor fallback we use
% the default sans-serif.
\setbeamerfont{title}{size=\LARGE, series=\bfseries}
\setbeamerfont{subtitle}{size=\large, series=\normalfont}
\setbeamerfont{frametitle}{size=\large, series=\bfseries}
\setbeamerfont{block title}{size=\normalsize, series=\bfseries}

% ── Footer ────────────────────────────────────────────────────────────────────
\setbeamertemplate{footline}{%
  \leavevmode%
  \hbox{%
    \begin{beamercolorbox}[wd=.4\paperwidth,ht=2.5ex,dp=1ex,left,leftskip=2mm]{palette tertiary}%
      \usebeamerfont{author in head/foot}\insertshortauthor
    \end{beamercolorbox}%
    \begin{beamercolorbox}[wd=.35\paperwidth,ht=2.5ex,dp=1ex,center]{palette secondary}%
      \usebeamerfont{title in head/foot}\insertshorttitle
    \end{beamercolorbox}%
    \begin{beamercolorbox}[wd=.25\paperwidth,ht=2.5ex,dp=1ex,right,rightskip=2mm]{palette primary}%
      \usebeamerfont{date in head/foot}%
      \insertframenumber{} / \inserttotalframenumber
    \end{beamercolorbox}%
  }%
  \vskip0pt%
}

% ── Navigation symbols: off ───────────────────────────────────────────────────
\setbeamertemplate{navigation symbols}{}

% ── Item bullets ─────────────────────────────────────────────────────────────
\setbeamertemplate{itemize item}{\textbullet}
\setbeamertemplate{itemize subitem}{--}
\setbeamertemplate{itemize subsubitem}{\tiny$\blacksquare$}

\endinput
